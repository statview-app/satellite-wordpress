{
    "name": "statview/satellite-wordpress",
    "description": "Statview Satellite plugin for WordPress",
    "type": "wordpress-plugin",
    "version": "1.0.0",
    "license": "MIT",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "brain/monkey": "^2.6",
        "pestphp/pest": "^2.0 || ^3.0",
        "yoast/phpunit-polyfills": "^2.0 || ^3.0",
        "wp-phpunit/wp-phpunit": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Statview\\Satellite\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Statview\\Satellite\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "test:unit": "pest --configuration=phpunit.xml.dist",
        "test:integration": "pest --configuration=phpunit.integration.xml.dist"
    }
}
